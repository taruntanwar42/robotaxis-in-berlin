<?xml version="1.0" encoding="UTF-8"?>
<configuration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/sumoConfiguration.xsd">
    <input>
        <net-file value="reinickendorf-district.net.xml"/>
        <route-files value="reinickendorf-district-contained.rou.xml.gz"/>
    </input>
    <output>
        <output-prefix value="output/reinickendorf_district_0600_0700_"/>
        <log value="console_0600_0700.log"/>
        <summary-output value="summary_0600_0700.xml"/>
        <statistic-output value="statistics_0600_0700.xml"/>
    </output>
    <time>
        <begin value="21600.0"/>
        <end value="25200.0"/>
    </time>
    <processing>
        <route-steps value="200"/>
        <no-internal-links value="false"/>
        <ignore-junction-blocker value="20"/>
        <time-to-teleport value="120.0"/>
        <time-to-teleport.highways value="0"/>
        <eager-insert value="false"/>
    </processing>
    <random_number>
        <random value="false"/>
        <seed value="251920"/>
    </random_number>
</configuration>
